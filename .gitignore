# Evidence media — never commit originals or derivatives
evidence/originals/*
!evidence/originals/.gitkeep
evidence/processed/*
!evidence/processed/.gitkeep
!evidence/processed/*_UPLOAD.json
evidence/publish/*
!evidence/publish/.gitkeep
evidence/export/*
!evidence/export/.gitkeep

# Incident register may contain GPS, police refs, YouTube URLs
register/incidents.csv
register/manifests/*.json
register/takedowns.csv
!register/manifests/.gitkeep

# YouTube OAuth secrets (never commit)
config/client_secret.json
config/youtube-token.json
config/import-inbox.conf

# Import watcher log (may contain paths)
register/import-inbox.log

# Python bytecode (pre-commit py_compile)
__pycache__/
*.py[cod]

# Branding — only YouTube-sized production assets are tracked
branding/*
!branding/reckless-rides-channel-icon-800x800.png
!branding/reckless-rides-channel-banner-2560x1440.png
!branding/reckless-rides-watermark-150x150.png
